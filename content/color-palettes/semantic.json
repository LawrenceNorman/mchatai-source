{
  "id": "semantic",
  "version": "1.0.0",
  "format": "json:color-palette/v1",
  "description": "Semantic UI palette — success/warning/error/info/neutral with light, base, and dark variants per role. Values derived from Tailwind 500-tier defaults because they're widely recognized and meet WCAG AA contrast on white when used as text on light backgrounds. Use this for status badges, toast messages, form validation, and any UI state that needs to communicate severity at a glance.",
  "colors": [
    { "name": "success",       "hex": "#22C55E", "role": "success", "tier": "base"  },
    { "name": "success-light", "hex": "#86EFAC", "role": "success", "tier": "light" },
    { "name": "success-dark",  "hex": "#15803D", "role": "success", "tier": "dark"  },
    { "name": "warning",       "hex": "#F59E0B", "role": "warning", "tier": "base"  },
    { "name": "warning-light", "hex": "#FCD34D", "role": "warning", "tier": "light" },
    { "name": "warning-dark",  "hex": "#B45309", "role": "warning", "tier": "dark"  },
    { "name": "error",         "hex": "#EF4444", "role": "error",   "tier": "base"  },
    { "name": "error-light",   "hex": "#FCA5A5", "role": "error",   "tier": "light" },
    { "name": "error-dark",    "hex": "#B91C1C", "role": "error",   "tier": "dark"  },
    { "name": "info",          "hex": "#3B82F6", "role": "info",    "tier": "base"  },
    { "name": "info-light",    "hex": "#93C5FD", "role": "info",    "tier": "light" },
    { "name": "info-dark",     "hex": "#1D4ED8", "role": "info",    "tier": "dark"  },
    { "name": "neutral",       "hex": "#6B7280", "role": "neutral", "tier": "base"  },
    { "name": "neutral-light", "hex": "#D1D5DB", "role": "neutral", "tier": "light" },
    { "name": "neutral-dark",  "hex": "#374151", "role": "neutral", "tier": "dark"  }
  ]
}
