{
  "id": "length",
  "version": "1.0.0",
  "format": "json:unit-conversions/v1",
  "description": "Linear length conversions. All factors are multipliers TO the base unit (meter). Convert A→B via: valueInBase = value * unitA.toBase; result = valueInBase / unitB.toBase.",
  "baseUnit": "m",
  "units": [
    { "id": "mm",   "name": "millimeter",  "toBase": 0.001,    "system": "metric"   },
    { "id": "cm",   "name": "centimeter",  "toBase": 0.01,     "system": "metric"   },
    { "id": "m",    "name": "meter",       "toBase": 1.0,      "system": "metric"   },
    { "id": "km",   "name": "kilometer",   "toBase": 1000.0,   "system": "metric"   },
    { "id": "in",   "name": "inch",        "toBase": 0.0254,   "system": "imperial" },
    { "id": "ft",   "name": "foot",        "toBase": 0.3048,   "system": "imperial" },
    { "id": "yd",   "name": "yard",        "toBase": 0.9144,   "system": "imperial" },
    { "id": "mi",   "name": "mile",        "toBase": 1609.344, "system": "imperial" },
    { "id": "nmi",  "name": "nautical mile", "toBase": 1852.0, "system": "nautical" }
  ]
}
