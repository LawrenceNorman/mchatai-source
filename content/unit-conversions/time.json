{
  "id": "time",
  "version": "1.0.0",
  "format": "json:unit-conversions/v1",
  "description": "Linear time conversions. All factors are multipliers TO the base unit (second). 'month' and 'year' use civil-calendar averages (365.25-day year) — use a calendar library for date arithmetic, this table is for elapsed-duration math only.",
  "baseUnit": "s",
  "units": [
    { "id": "ns",    "name": "nanosecond",   "toBase": 1e-9         },
    { "id": "us",    "name": "microsecond",  "toBase": 1e-6         },
    { "id": "ms",    "name": "millisecond",  "toBase": 0.001        },
    { "id": "s",     "name": "second",       "toBase": 1.0          },
    { "id": "min",   "name": "minute",       "toBase": 60.0         },
    { "id": "hr",    "name": "hour",         "toBase": 3600.0       },
    { "id": "day",   "name": "day",          "toBase": 86400.0      },
    { "id": "week",  "name": "week",         "toBase": 604800.0     },
    { "id": "month", "name": "month (avg)",  "toBase": 2629800.0    },
    { "id": "year",  "name": "year (Julian)","toBase": 31557600.0   }
  ]
}
