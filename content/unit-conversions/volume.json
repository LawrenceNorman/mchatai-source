    { "id": "m3",       "name": "cubic meter",      "toBase": 1000.0,     "system": "metric"        },
    { "id": "us-tsp",   "name": "US teaspoon",      "toBase": 0.00492892, "system": "us-customary"  },
    { "id": "us-tbsp",  "name": "US tablespoon",    "toBase": 0.01478676, "system": "us-customary"  },
    { "id": "us-floz",  "name": "US fluid ounce",   "toBase": 0.02957353, "system": "us-customary"  },
    { "id": "us-cup",   "name": "US cup",           "toBase": 0.2365882,  "system": "us-customary"  },
    { "id": "us-pt",    "name": "US pint",          "toBase": 0.4731765,  "system": "us-customary"  },
    { "id": "us-qt",    "name": "US quart",         "toBase": 0.9463529,  "system": "us-customary"  },
    { "id": "us-gal",   "name": "US gallon",        "toBase": 3.7854118,  "system": "us-customary"  },
    { "id": "uk-floz",  "name": "UK fluid ounce",   "toBase": 0.02841306, "system": "imperial"      },
    { "id": "uk-pt",    "name": "UK pint",          "toBase": 0.5682613,  "system": "imperial"      },
    { "id": "uk-gal",   "name": "UK gallon",        "toBase": 4.5460900,  "system": "imperial"      }
  ]
}
