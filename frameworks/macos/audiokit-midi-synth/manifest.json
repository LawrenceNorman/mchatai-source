{
  "id": "framework.macos.audiokit-midi-synth",
  "name": "AudioKit MIDI Synth Keyboard",
  "framework": "audiokit",
  "frameworkVersion": "5.6+",
  "platform": "macos",
  "minMacOS": "12.0",
  "type": "framework-scaffold",
  "version": "1.0.0",
  "complexity": "starter",
  "loc": 280,
  "createdBy": "AIWizard team",
  "createdAt": "2026-04-13",
  "description": "Playable on-screen MIDI keyboard with selectable oscillator (sine/square/saw/triangle) and ADSR envelope. Foundation for synth, sequencer, drum machine, FX rack, and DAW-lite extensions.",
  "demonstrates": [
    "AudioEngine setup and lifecycle",
    "DynamicOscillator with selectable waveforms",
    "AmplitudeEnvelope (ADSR)",
    "AudioKitUI KeyboardView wiring",
    "MIDI note → frequency mapping",
    "SwiftUI ↔ Conductor pattern"
  ],
  "extensionPaths": [
    "Add MIDIKit for external keyboard input",
    "Add SoundpipeAudioKit Reverb/Delay effects chain",
    "Add AppleSequencer for spreadsheet-style sequencer",
    "Add Tonic for chord/scale awareness",
    "Add multi-track Mixer for DAW-lite features"
  ],
  "dependencies": [
    { "url": "https://github.com/AudioKit/AudioKit.git", "from": "5.6.0", "product": "AudioKit" },
    { "url": "https://github.com/AudioKit/AudioKitUI.git", "from": "0.4.0", "product": "AudioKitUI" }
  ],
  "entitlements": ["microphone"],
  "buildCommand": "swift build",
  "runCommand": "swift run",
  "tags": ["audio", "midi", "music", "synthesizer", "audiokit", "macos"],
