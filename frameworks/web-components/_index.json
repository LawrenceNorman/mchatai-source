  "goldenAssemblies": [
    {
      "id": "assembly.asteroids.vector-core",
      "name": "Asteroids Golden Assembly",
      "summary": "Runnable Asteroids example composed from the shared engine, entity, swatch, and HUD modules.",
      "recipeID": "recipe.arcade-top-down",
      "templateIDs": [
        "asteroids-clone"
      ],
      "keywords": [
        "asteroids",
