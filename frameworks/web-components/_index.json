{
  "$schema_version": "1.1.0",
  "last_updated": "2026-05-01",
  "notes": "Catalog for reusable vanilla ES6 mini-app Lego blocks. AIWizard should compose from these modules before generating custom logic. Prefer local bundling into published mini-app ZIPs; CDN loading is only a development option.",
  "library": {
    "id": "framework.web-components",
    "name": "Web Mini-App Lego Blocks",
    "platform": "web",
    "runtime": "vanilla-es6-modules",
    "preferredDistribution": "bundled",
    "alternateDistribution": "cdn",
    "importStyle": "relative-esm",
    "entryPoints": [
      "core/GameManager.js",
      "core/Physics2D.js",
      "core/TurnBasedManager.js",
      "entities/Entity.js",
      "entities/SpaceShip.js",
      "entities/Asteroid.js",
      "entities/Projectile.js",
      "entities/Paddle.js",
      "entities/Ball.js",
      "entities/GridBoard.js",
      "entities/Board8x8.js",
      "entities/Card.js",
      "entities/Deck.js",
      "entities/PlatformerPlayer.js",
      "entities/PathFollower.js",
      "entities/GridMover.js",
      "entities/Match3Logic.js",
      "entities/RevealLogic.js",
      "entities/LetterGrid.js",
      "entities/WaveManager.js",
      "entities/Turret.js",
      "entities/CameraFollow.js",
      "ui/ScoreBoard.js",
      "ui/VirtualJoystick.js",
      "ui/PianoKeyboard.js",
      "resources/Swatches.js",
      "resources/AudioManager.js"
    ]
  },
  "categories": [
    {
      "id": "core",
      "displayName": "Core Engines",
      "description": "Loop, timing, state, motion, and collision primitives shared by many mini-app genres."
    },
    {
      "id": "entities",
      "displayName": "Entities",
      "description": "Composable gameplay actors such as ships, paddles, cards, boards, tile grids, and player avatars."
    },
    {
      "id": "ui",
      "displayName": "UI",
      "description": "Reusable overlays, HUD widgets, and control surfaces that can be re-skinned per swatch."
    },
    {
      "id": "resources",
      "displayName": "Resources",
      "description": "Swatches, audio, textures, and other shared presentation assets."
    }
  ],
  "components": [
    {
      "id": "core.game-manager",
      "name": "GameManager",
      "category": "core",
      "path": "core/GameManager.js",
      "exports": ["GameManager"],
      "status": "ready",
      "summary": "requestAnimationFrame baseplate with delta time, pause/resume, resize support, events, collision callbacks, and entity lifecycle management.",
      "tags": ["engine", "loop", "canvas", "arcade", "miniapp"],
      "contracts": {
        "entityUpdate": "entity.update(dt, gameManager)",
        "entityDraw": "entity.draw(ctx, gameManager)",
        "entityLifecycle": ["entity.onAdd(gameManager)", "entity.onRemove(gameManager)"]
      },
      "goodFits": ["asteroids", "pong", "frogger", "pacman", "alien-abduction", "tower-defense", "platformers"]
    },
    {
      "id": "core.physics2d",
      "name": "Physics2D",
      "category": "core",
      "path": "core/Physics2D.js",
      "exports": ["Physics2D", "getAABB", "getCircle", "integrateMotion", "intersectsAABB", "intersectsCircle", "findAABBCollisions", "findCircleCollisions"],
      "status": "ready",
      "summary": "Simple motion integrator plus AABB and circle collision helpers for lightweight 2D arcade and platformer logic.",
      "tags": ["physics", "collision", "motion", "2d"],
      "contracts": {
        "bodyFields": ["x", "y", "width", "height", "vx", "vy", "ax", "ay", "radius"],
        "optionalFields": ["maxSpeed", "maxSpeedX", "maxSpeedY", "centered", "bounds", "hitbox"]
      },
      "goodFits": ["asteroids", "pong", "mario-style-platformers", "tower-defense-projectiles", "top-down-arcade"]
    },
    {
      "id": "core.turn-based-manager",
      "name": "TurnBasedManager",
      "category": "core",
      "path": "core/TurnBasedManager.js",
      "exports": ["TurnBasedManager"],
      "status": "ready",
      "summary": "Turn, phase, round, history, and rule dispatcher baseplate for board, card, word, and puzzle games.",
      "tags": ["turn-based", "state-machine", "rules", "board", "card", "puzzle"],
      "contracts": {
        "events": ["turn", "phase", "round", "record", "reset"],
        "rules": ["registerRule(name, fn)", "runRule(name, payload)"]
      },
      "goodFits": ["blackjack", "texas-holdem-poker", "chess", "checkers", "mastermind", "word-quest", "minesweeper-99", "candy-match"]
    },
    {
      "id": "entities.entity",
      "name": "Entity",
      "category": "entities",
      "path": "entities/Entity.js",
      "exports": ["Entity"],
      "status": "ready",
      "summary": "Lightweight gameplay base class with motion fields, world wrapping helpers, AABB/circle hit shapes, and reusable lifecycle hooks.",
      "tags": ["entity", "gameplay", "base-class", "arcade"],
      "contracts": {
        "constructor": "new Entity({ x, y, vx, vy, width, height, radius, wrap })",
        "lifecycle": ["update(dt, gameManager)", "draw(ctx, gameManager)", "destroy()"]
      },
      "goodFits": ["asteroids", "alien-abduction", "pong", "frogger", "top-down-arcade"]
    },
    {
      "id": "entities.space-ship",
