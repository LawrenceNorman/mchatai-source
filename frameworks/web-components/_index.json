      "summary": "Asteroids-style player ship with thrust, rotation, drag, wrapping, and projectile spawning.",
      "tags": ["player", "ship", "asteroids", "arcade"],
      "contracts": {
        "controls": ["setInputState({ left, right, thrust, fire })", "createProjectile({ speed, ttl })"],
        "tuning": ["turnSpeed", "thrustPower", "drag", "maxSpeed"]
