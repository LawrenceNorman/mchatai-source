{
  "schemaVersion": 1,
  "engine": "word-grid",
  "id": "lexi-grid",
  "title": "Lexi Grid",
  "genre": "word-grid-hybrid",
  "version": 1,
  "board": {
    "type": "letter-grid",
    "width": 5,
    "height": 5
  },
  "rules": {
    "turnModel": "single-player",
    "mode": "word-hunt",
    "winCondition": "find-all-target-words-before-timer-expires",
    "loseCondition": "timer-expires",
    "hints": false,
    "timerSeconds": 120
  },
  "content": {
    "dictionary": "embedded-starter",
    "locale": "en-US",
    "puzzlePath": "puzzle.json",
    "seedWords": [
      "CODE",
      "CHAT",
      "GRID",
      "HOME",
      "SAFARI"
    ]
  },
  "ui": {
    "theme": "aurora-grid",
    "inputMode": "touch-drag-or-tap",
    "instructions": "Find the hidden words by tapping or dragging across adjacent letters. This build is packaged as a portable standalone web bundle.",
    "themeTokens": {
      "bg": "#07111f",
      "panel": "rgba(10, 26, 46, 0.86)",
      "panel-border": "rgba(147, 197, 253, 0.18)",
      "tile": "#10243d",
      "tile-active": "#1d4ed8",
      "tile-found": "#14532d",
      "text": "#eff6ff",
      "muted": "#a5b4fc",
      "accent": "#7dd3fc",
      "danger": "#fb7185",
      "button-text": "#031525"
    }
  },
  "assets": {
    "inline": true
  }
}
