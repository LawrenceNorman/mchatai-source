{
  "schemaVersion": 1,
  "engine": "word-grid",
  "id": "nature-grid",
  "title": "Nature Grid",
  "genre": "word-grid-hybrid",
  "version": 1,
  "board": {
    "type": "letter-grid",
    "width": 5,
    "height": 5
  },
  "rules": {
    "turnModel": "single-player",
    "mode": "word-hunt",
    "winCondition": "find-all-target-words-before-timer-expires",
    "loseCondition": "timer-expires",
    "hints": false,
    "timerSeconds": 120
  },
  "content": {
    "dictionary": "embedded-starter",
    "locale": "en-US",
    "puzzlePath": "puzzle.json",
    "seedWords": [
      "LEAF",
      "PINE",
      "RAIN",
      "LAKE",
      "FERN"
    ]
  },
  "ui": {
    "theme": "forest-dew",
    "inputMode": "touch-drag-or-tap",
    "instructions": "Explore the grid and find nature words hidden among the letters. Drag or tap to spell them out!",
    "themeTokens": {
      "bg": "#052e16",
      "panel": "rgba(5, 46, 22, 0.88)",
      "panel-border": "rgba(134, 239, 172, 0.18)",
      "tile": "#14532d",
      "tile-active": "#15803d",
      "tile-found": "#365314",
      "text": "#f0fdf4",
      "muted": "#bbf7d0",
      "accent": "#86efac",
      "danger": "#fca5a5",
      "button-text": "#052e16"
    }
  },
  "assets": {
    "inline": true
  }
}
