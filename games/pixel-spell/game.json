{
  "schemaVersion": 1,
  "engine": "word-grid",
  "id": "pixel-spell",
  "title": "Pixel Spell",
  "genre": "word-grid-hybrid",
  "version": 1,
  "board": {
    "type": "letter-grid",
    "width": 5,
    "height": 5
  },
  "rules": {
    "turnModel": "single-player",
    "mode": "word-hunt",
    "winCondition": "find-all-target-words-before-timer-expires",
    "loseCondition": "timer-expires",
    "hints": false,
    "timerSeconds": 90
  },
  "content": {
    "dictionary": "embedded-starter",
    "locale": "en-US",
    "puzzlePath": "puzzle.json",
    "seedWords": [
      "PIXEL",
      "GAME",
      "JUMP",
      "COIN",
      "LEVEL"
    ]
  },
  "ui": {
    "theme": "retro-arcade",
    "inputMode": "touch-drag-or-tap",
    "instructions": "Retro mode! Find all 5 gaming words in just 90 seconds. Tap or drag to spell.",
    "themeTokens": {
      "bg": "#18181b",
      "panel": "rgba(24, 24, 27, 0.9)",
      "panel-border": "rgba(250, 204, 21, 0.2)",
      "tile": "#27272a",
      "tile-active": "#eab308",
      "tile-found": "#713f12",
      "text": "#fefce8",
      "muted": "#fde68a",
      "accent": "#facc15",
      "danger": "#f87171",
      "button-text": "#18181b"
    }
  },
  "assets": {
    "inline": true
  }
}
