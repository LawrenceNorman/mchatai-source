{
  "schemaVersion": 1,
  "engine": "word-grid",
  "id": "word-forge",
  "title": "Word Forge",
  "genre": "word-grid-hybrid",
  "version": 1,
  "board": {
    "type": "letter-grid",
    "width": 5,
    "height": 5
  },
  "rules": {
    "turnModel": "single-player",
    "mode": "word-hunt",
    "winCondition": "find-all-target-words-before-timer-expires",
    "loseCondition": "timer-expires",
    "hints": false,
    "timerSeconds": 150
  },
  "content": {
    "dictionary": "embedded-starter",
    "locale": "en-US",
    "puzzlePath": "puzzle.json",
    "seedWords": [
      "FORGE",
      "STEEL",
      "FLAME",
      "IRON",
      "HEAT"
    ]
  },
  "ui": {
    "theme": "ember-forge",
    "inputMode": "touch-drag-or-tap",
    "instructions": "Find the hidden words by tapping or dragging across adjacent letters. Forge all 5 words before the timer runs out!",
    "themeTokens": {
      "bg": "#1a0a00",
      "panel": "rgba(40, 15, 0, 0.88)",
      "panel-border": "rgba(255, 140, 50, 0.2)",
      "tile": "#2d1200",
      "tile-active": "#c2410c",
      "tile-found": "#854d0e",
      "text": "#fef3c7",
      "muted": "#fdba74",
      "accent": "#fb923c",
      "danger": "#ef4444",
      "button-text": "#1a0a00"
    }
  },
  "assets": {
    "inline": true
  }
}
