{
  "version": 6,
  "surface": "aiwizard",
  "description": "Default context recipe for AIWizard macOS-app generation. Loads in priority order: framework scaffold > macOS app builder capability pack > active memory > universal wisdom > framework-specific wisdom > native macOS Lego components > frontend-skill guidance > feature manifest > user goal > recent history. Each layer skips cleanly when its prerequisite isn't available. v2 added active-memory layer (Phase MA.3). v3 adds excludeTitlePatterns to drop CCAA / AgentRuntime / ScheduledJob log spam from retrieval results. v4 (2026-04-20): Phase DF — added frontend-skill-guidance layer at priority 82. v5 (Phase CAP): added macos-app-builder capability pack at priority 98. v6 (2026-05-02): added macos-components layer at priority 84 for source-copy SwiftUI Lego components.",
  "layers": [
    {
      "id": "framework-scaffold",
      "loader": "framework-scaffold",
      "priority": 100,
      "maxTokens": 12000
    },
    {
      "id": "macos-app-builder-pack",
      "loader": "capability-pack",
      "priority": 98,
      "maxTokens": 5000,
      "options": {
        "packID": "macos-app-builder"
      }
    },
    {
      "id": "active-memory",
      "loader": "active-memory",
      "priority": 95,
      "maxTokens": 1500,
      "options": {
        "budgetChars": 6000,
        "budgetMillis": 400,
        "excludeTitlePatterns": [
          "^\\[CCAA\\]",
          "^\\[AgentRuntime_",
          "^\\[ScheduledJob\\]"
        ]
      }
    },
    {
      "id": "wisdom-universal",
      "loader": "wisdom-universal",
      "priority": 90,
      "maxTokens": 3000
    },
    {
      "id": "wisdom-framework",
      "loader": "wisdom-framework",
      "priority": 85,
      "maxTokens": 3000
    },
    {
      "id": "macos-components",
      "loader": "macos-components",
      "priority": 84,
      "maxTokens": 9000,
      "options": {
        "maxComponents": 8,
        "maxSourceBytes": 46000
      }
    },
    {
      "id": "frontend-skill-guidance",
      "loader": "wisdom-pack",
      "priority": 82,
      "maxTokens": 3500,
      "options": {
        "packID": "frontend-skill"
      }
    },
    {
      "id": "user-references",
      "loader": "user-references",
      "priority": 78,
      "maxTokens": 6000,
      "options": {
        "includeImageData": false
      }
    },
    {
      "id": "feature-manifest",
      "loader": "feature-manifest",
      "priority": 70,
      "maxTokens": 1500
    },
    {
      "id": "user-goal",
      "loader": "user-goal",
      "priority": 60,
      "maxTokens": 1000
    },
    {
      "id": "history-recent",
      "loader": "history-recent",
      "priority": 50,
      "maxTokens": 2000,
      "options": {
        "limit": 5,
        "includeAssistant": true
      }
    }
  ]
}
