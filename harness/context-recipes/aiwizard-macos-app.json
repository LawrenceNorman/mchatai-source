{
  "version": 1,
  "surface": "aiwizard",
  "description": "Default context recipe for AIWizard macOS-app generation. Loads in priority order: framework scaffold > universal wisdom > framework-specific wisdom > feature manifest > user goal > recent history. Each layer skips cleanly when its prerequisite isn't available.",
  "layers": [
    {
      "id": "framework-scaffold",
      "loader": "framework-scaffold",
      "priority": 100,
      "maxTokens": 12000
    },
    {
      "id": "wisdom-universal",
      "loader": "wisdom-universal",
      "priority": 90,
      "maxTokens": 3000
    },
    {
      "id": "wisdom-framework",
      "loader": "wisdom-framework",
      "priority": 85,
      "maxTokens": 3000
    },
    {
      "id": "feature-manifest",
      "loader": "feature-manifest",
      "priority": 70,
      "maxTokens": 1500
    },
    {
      "id": "user-goal",
      "loader": "user-goal",
      "priority": 60,
      "maxTokens": 1000
    },
    {
      "id": "history-recent",
      "loader": "history-recent",
      "priority": 50,
      "maxTokens": 2000,
      "options": {
        "limit": 5,
        "includeAssistant": true
      }
    }
  ]
}
