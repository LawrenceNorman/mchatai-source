{
  "version": 1,
  "surface": "aiwizard",
  "description": "Context recipe for AIWizard mini-app (single-file HTML) generation. Lighter than the macOS-app recipe — no framework scaffold (mini-apps are self-contained HTML) and a tighter token budget overall.",
  "layers": [
    {
      "id": "wisdom-universal",
      "loader": "wisdom-universal",
      "priority": 90,
      "maxTokens": 2500
    },
    {
      "id": "feature-manifest",
      "loader": "feature-manifest",
      "priority": 70,
      "maxTokens": 1200
    },
    {
      "id": "user-goal",
      "loader": "user-goal",
      "priority": 60,
      "maxTokens": 800
    },
    {
      "id": "history-recent",
      "loader": "history-recent",
      "priority": 50,
      "maxTokens": 1500,
      "options": {
        "limit": 4,
        "includeAssistant": true
      }
    }
  ]
}
