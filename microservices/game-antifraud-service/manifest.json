{
  "id": "official.game-antifraud-service",
  "name": "Game Anti-Fraud Service",
  "version": "1.0.0",
  "type": "microservice",
  "runtime": "python3",
  "description": "Score anomaly detection and token usage fraud prevention. HMAC-signed score verification, statistical outlier detection, device fingerprinting.",
  "author": "mchatai-labs",
  "license": "MIT",
  "platforms": ["mchatai-macos", "mchatai-ios", "mchatai-android"],
  "cloudRun": {
    "service": "game-antifraud-service",
    "region": "us-central1",
    "project": "mchatai-2367e",
    "memory": "256Mi",
    "minInstances": 0,
    "maxInstances": 5
  },
  "endpoints": [
    "POST /verify/score",
    "POST /verify/token-usage",
    "GET /health"
  ],
  "auth": "firebase-id-token"
}
