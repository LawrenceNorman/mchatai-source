{
  "id": "official.icon-maker",
  "name": "Icon Maker",
  "version": "1.1.0",
  "type": "microservice",
  "runtime": "python3",
  "description": "Compose app icons (PNG + .icns + AppIcon.appiconset) from Material Icons, game-icons.net glyphs, gradients, textures, and text overlays. Headless sibling of the macOS Icon Maker app.",
  "author": "mchatai-labs",
  "license": "MIT",
  "platforms": ["mchatai-shell"],
  "tags": ["icon", "media", "composition", "png", "icns", "appiconset", "material-icons", "game-icons"],
  "endpoints": [
    "/compose",
    "/preview",
    "/info",
    "/symbols/material/categories",
    "/symbols/material/search",
    "/symbols/material/{icon_id}",
    "/healthz"
  ],
  "bundled_assets": [
    "assets/MaterialIconsRound.otf",
    "assets/material_icons_catalog.json",
    "assets/sf_symbol_hints.json",
    "assets/game_icons/catalog.json",
    "assets/game_icons/LEDGER.json",
    "assets/game_icons/LICENSE.md",
    "assets/game_icons/png/"
  ]
}
