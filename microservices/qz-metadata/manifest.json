{
  "id": "official.qz-metadata",
  "name": "Quiznect Metadata",
  "version": "1.0.0",
  "type": "microservice",
  "runtime": "python3",
  "description": "Pure-compute metadata operations for quiz data — tagging, wrapping, token counting, ID generation",
  "author": "mchatai-labs",
  "license": "MIT",
  "platforms": ["mchatai-cloud"],
  "cloudConfig": {
    "cloudRunService": "mchatai-qz-metadata",
    "region": "us-central1",
    "minInstances": 0,
    "maxInstances": 10,
    "memory": "256Mi",
    "cpu": "1",
    "timeoutSeconds": 60
  },
  "endpoints": [
    {
      "path": "/add-tags",
      "method": "POST",
      "description": "Attach tags to question set",
      "estimatedTokenCost": 0
    },
    {
      "path": "/wrap-metadata",
      "method": "POST",
      "description": "Wrap questions with metadata structure",
      "estimatedTokenCost": 0
    },
    {
      "path": "/count-tokens",
      "method": "POST",
      "description": "Count tokens in text via tiktoken",
      "estimatedTokenCost": 0
    },
    {
      "path": "/generate-tags",
      "method": "POST",
      "description": "Generate tags from text by extracting keywords",
      "estimatedTokenCost": 0
    },
    {
      "path": "/add-ids",
      "method": "POST",
      "description": "Add unique UUIDs to questions",
      "estimatedTokenCost": 0
    },
    {
      "path": "/search-keywords",
      "method": "POST",
      "description": "Extract search keywords from quiz data",
      "estimatedTokenCost": 0
    }
  ]
}
