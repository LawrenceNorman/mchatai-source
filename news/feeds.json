    "source.category": "one of the app categories incl. Local, Videos",
    "source.language": "BCP-ish code the language filter matches; gnews-* are 'en' and localize by region in pass 1",
    "source.{latitude,longitude}": "for the globe view",
    "source.icon": "SF Symbol",
    "health (cron-written, app ignores)": "healthStatus: ok|flaky|dead, lastChecked, lastHttpStatus, newestItemAgeHours"
