{
  "_doc": "Configuration for EndProductPublishView.composeRequestFromProduct. Move-rule-from-Swift content. Iterate freely; takes effect on next refreshMchataisourceCache.",
  "_version": 2,
  "llm_picker": {
    "_doc": "Backend ladder for the LLM symbol picker. Tried in order; first available wins. The user's CloudProvider.getActive() is auto-prepended at runtime so the user's chosen provider gets first dibs. 'foundation' is Apple Intelligence (always available on supported devices, free, on-device). Set llm_picker.enabled=false to bypass the LLM and use the deterministic fallback below.",
    "enabled": true,
    "fallback_ladder": [
      "foundation",
      "google",
      "anthropic",
      "openAI",
      "ollama",
      "mChatAICloud"
    ],
    "temperature": 0.2,
    "timeout_seconds": 12,
    "max_output_tokens": 200
  },
